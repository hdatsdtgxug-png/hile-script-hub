-- Delta ve tüm mobil executor'lar için optimize edilmiş yükleme
local Lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/bloodball/-back-ups-for-libs/main/wall"))()
local Win = Lib:CreateWindow("KAOS & SAVAŞ PANELİ")

-- 1. SAVAŞ ALANI
local Savas = Win:CreateFolder("⚔️ SAVAŞ ALANI")
Savas:AddToggle("🚀 HIZ (Speed)", function(val) getgenv().Speed = val spawn(function() while getgenv().Speed do game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 100 task.wait() end game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16 end) end)
Savas:AddToggle("⚡ ZIPLAMA (Jump)", function(val) getgenv().Jump = val spawn(function() while getgenv().Jump do game.Players.LocalPlayer.Character.Humanoid.JumpPower = 100 task.wait() end game.Players.LocalPlayer.Character.Humanoid.JumpPower = 50 end) end)
Savas:AddToggle("🛸 UÇMA (Fly)", function(val) getgenv().Fly = val local hum = game.Players.LocalPlayer.Character:FindFirstChild("Humanoid") spawn(function() while getgenv().Fly do hum.PlatformStand = true task.wait() end hum.PlatformStand = false end) end)
Savas:AddToggle("🧱 DUVAR GEÇME (NoClip)", function(val) getgenv().NoClip = val spawn(function() while getgenv().NoClip do for _, part in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end task.wait() end end) end)

-- 2. TROLL BÖLÜMÜ
local Troll = Win:CreateFolder("🌪️ TROLL BÖLÜMÜ")
Troll:AddToggle("😵 EKRAN BOZUCU (Fling)", function(val) getgenv().Fling = val spawn(function() while getgenv().Fling do if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then game.Players.LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(9999, 9999, 9999) end task.wait() end end) end)
Troll:AddToggle("👣 YÜRÜYÜŞ BOZUCU (SERT)", function(val) getgenv().WalkBreak = val spawn(function() while getgenv().WalkBreak do if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 0.2) end task.wait(0.05) end end) end)
Troll:AddToggle("🛑 YÜRÜYÜŞ KİLİTLEYİCİ", function(val) getgenv().Freeze = val spawn(function() while getgenv().Freeze do game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 0 task.wait(0.5) game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 100 task.wait(0.1) end end) end)

-- 3. EŞYALAR
local Esya = Win:CreateFolder("📦 TROLL EŞYALARI")
Esya:AddButton("🔫 REMINGTON 870", function() if game.Workspace:FindFirstChild("Prison_ITEMS") then game.Workspace.Prison_ITEMS.giver["Remington 870"]:Clone().Parent = game.Players.LocalPlayer.Backpack end end)
Esya:AddButton("🗝️ POLİS KARTI", function() if game.Workspace:FindFirstChild("Prison_ITEMS") then game.Workspace.Prison_ITEMS.giver["Key"]:Clone().Parent = game.Players.LocalPlayer.Backpack end end)

-- DELTA İÇİN EN UYUMLU PANEL KONTROLÜ
-- Win:Toggle() komutu kütüphanenin içinde zaten var, onu kullanıyoruz.
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 120, 0, 40)
MainFrame.Position = UDim2.new(0.5, 0, 0.05, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
MainFrame.Draggable = true 

local ToggleBtn = Instance.new("TextButton", MainFrame)
ToggleBtn.Size = UDim2.new(0.7, 0, 1, 0)
ToggleBtn.Text = "AÇ/KAPA"
ToggleBtn.TextColor3 = Color3.new(1,1,1)
ToggleBtn.MouseButton1Click:Connect(function() Win:Toggle() end)

local CloseBtn = Instance.new("TextButton", MainFrame)
CloseBtn.Size = UDim2.new(0.3, 0, 1, 0)
CloseBtn.Position = UDim2.new(0.7, 0, 0, 0)
CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.new(1,0,0)
CloseBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

-- CHAT KOMUTU
game.Players.LocalPlayer.Chatted:Connect(function(msg)
    if msg:lower() == "/panel" then Win:Toggle() end
end)
